scalar BigDecimal
scalar LocalDateTime

interface Base {
    id: ID!
    createdAt: LocalDateTime!
    createdBy: String!
    updatedAt: LocalDateTime!
    updatedBy: String
}

type PageInfo {
    number: Int!
    size: Int!
    totalElements: Int!
    totalPages: Int!
}

enum CurrencyCode {
    USD
    EUR
    GBP
    CAD
    AUD
    JPY
}

enum Status {
    ACTIVE
    ARCHIVED
    CLOSED
}

enum SortDirection {
    ASC
    DESC
}