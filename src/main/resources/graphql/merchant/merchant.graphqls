extend type Query {
    merchants: [MerchantResponse!]!
    merchant(id: ID!): MerchantResponse
}

extend type Mutation {
    createMerchant(input: CreateMerchantInput!): MerchantResponse!
    updateMerchant(id: ID!, input: UpdateMerchantInput!): MerchantResponse!
    deleteMerchant(id: ID!): Boolean!
}

type MerchantResponse implements Base {
    id: ID!
    createdAt: LocalDateTime!
    createdBy: String!
    updatedAt: LocalDateTime!
    updatedBy: String
    workspaceId: ID!
    name: String!
    status: Status!
}

input CreateMerchantInput {
    name: String!
}

input UpdateMerchantInput {
    name: String
    status: Status
}
